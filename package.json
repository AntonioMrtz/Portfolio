{
  "name": "portfolio",
  "type": "module",
  "version": "2.0.0",
  "scripts": {
    "dev": "GA_ENABLED=false astro dev",
    "build": "GA_ENABLED=true astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint . --ext .js,.ts,.astro",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:e2e:server": "GA_ENABLED=false npm run build && npm run preview",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2:codegen": "playwright codegen http://localhost:4321/Portfolio",
    "prepare": "husky"
  },
  "dependencies": {
    "@alpinejs/intersect": "^3.15.12",
    "@astrojs/alpinejs": "^0.5.0",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.3.1",
    "@types/alpinejs": "^3.13.11",
    "alpinejs": "^3.15.12",
    "astro": "^7.0.0",
    "astro-navbar": "^2.4.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-plugin-astro": "^1.5.0",
    "husky": "^9.1.7",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
