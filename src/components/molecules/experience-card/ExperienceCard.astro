---
import { Image } from "astro:assets";
import TechBadge from "@/components/atoms/badges/TechBadge.astro";
import type { Badge } from "@/data/badges";
import type { ImageMetadata } from "astro";

interface Props {
  imgSrc: ImageMetadata;
  imgAlt: string;
  title: string;
  subheader?: string[];
  description?: string;
  badges: Badge[];
  forceCollapseDescription?: boolean;
  forceTechColumnDisplay?: boolean;
  fixedHeight?: number;
}

const {
  imgSrc,
  imgAlt,
  title,
  subheader,
  description,
  badges,
  forceCollapseDescription = false,
  forceTechColumnDisplay = false,
  fixedHeight,
} = Astro.props;

function parseSubheaderData(subheader: string[]): string {
  return subheader.join(" | ");
}
---

<div
  x-data="experienceCard"
  data-force-collapse={forceCollapseDescription}
  x-intersect:enter.once="revealed = true"
  x-bind:class="{ 'visible': revealed }"
  class={`card-container card-reveal flex flex-col-reverse ${forceTechColumnDisplay ? "" : "lg:flex-row"} gap-8 justify-between p-4 sm:p-8 w-full m-0 rounded-xl`}
  style={fixedHeight ? `height: ${fixedHeight}px;` : undefined}
>
  <div
    class={`flex flex-col ${forceTechColumnDisplay ? "" : "md:flex-row"} gap-8 lg:gap-12 min-w-0`}
  >
    <div class="flex justify-center md:justify-start">
      <Image
        class="w-30 min-w-30 sm:w-40 sm:min-w-40 h-30 min-h-40 sm:h-40 sm:min-h-40 object-contain rounded-xl aspect-auto"
        src={imgSrc}
        alt={imgAlt}
        width={160}
        height={160}
        loading="lazy"
        decoding="async"
        format="webp"
      />
    </div>
    <div class="flex flex-col gap-6 max-w-xl min-w-0">
      <div class="flex flex-col gap-2">
        <h3 class="font-bold text-lg md:text-2xl 2xl:text-3xl">{title}</h3>
        {
          subheader && (
            <h4 class="font-semibold text-md md:text-lg 2xl:text-xl">
              {parseSubheaderData(subheader)}
            </h4>
          )
        }
      </div>
      {
        description && (
          <div
            class="relative"
            x-bind:class="shouldCollapse ? 'cursor-pointer' : ''"
            x-on:click="toggle()"
          >
            <p
              class="whitespace-pre-line text-base 2xl:text-[1.2rem] transition-[max-height,opacity] duration-[400ms,300ms] ease-in-out"
              x-bind:class="!expanded && shouldCollapse ? 'max-h-32 overflow-hidden' : ''"
            >
              {description}
            </p>
            <div
              x-show="!expanded && shouldCollapse"
              x-transition:opacity
              class="absolute bottom-0 left-0 right-0 h-8 pointer-events-none"
              style="background: linear-gradient(to bottom, transparent, var(--card-bg))"
            />
          </div>
        )
      }
      <div class="flex flex-col md:flex-row items-center md:items-start gap-3">
        <slot name="actions" />
      </div>
    </div>
  </div>
  <div
    class={`flex flex-row ${forceTechColumnDisplay ? "" : "lg:flex-col"} flex-wrap gap-2`}
  >
    {badges.map((v) => <TechBadge imageUrl={v.imageUrl} altText={v.name} />)}
  </div>
</div>

<style>
  .card-container {
    --card-bg: var(--neutral-gray-100);
    border: 1px solid var(--secondary-purple-900);
    background: var(--card-bg);
    box-shadow:
      5px 5px 0px var(--neutral-gray-500),
      -5px -5px 0px var(--neutral-white);
  }

  .card-reveal {
    opacity: 0;
    transform: translateY(60px);
    transition:
      opacity 1.2s ease-out,
      transform 1.2s ease-out;
  }

  .card-reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
